{
  "name": "@encodium/rp-ui",
  "version": "1.77.2",
  "description": "RevolutionParts Component Library - UX Test version 1.0",
  "main": "src/index.js",
  "scripts": {
    "lint": "eslint --max-warnings 0 src/",
    "lint:ci": "eslint --no-color --max-warnings 0 src/",
    "test": "jest --verbose=false",
    "test:ci": "jest --ci --reporters=default --coverage",
    "prepare": "husky install",
    "commitlint": "commitlint --edit",
    "lint:fix": "eslint src/ --fix",
    "semantic-release": "semantic-release",
    "storybook": "storybook dev -p 6006",
    "storybook-no-browser-open": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/encodium/rp-ui.git"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.2.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.0.3",
    "@atlaskit/pragmatic-drag-and-drop-live-region": "^1.0.6",
    "@atlaskit/pragmatic-drag-and-drop-react-drop-indicator": "^1.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@mui/x-charts-pro": "^8.18.0",
    "@mui/x-data-grid-pro": "^8.19.0",
    "@mui/x-date-pickers-pro": "^8.19.0",
    "@mui/x-license": "^8.17.0",
    "@revolutionparts/number-format": "^2.6.1",
    "@testing-library/dom": "^10.3.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "formik": "^2.4.6",
    "lodash": "^4.17.21",
    "prop-types": "^15.8.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-lottie": "^1.2.10",
    "tiny-invariant": "^1.3.3",
    "tinymce": "^8.3.2",
    "uuid": "^10.0.0",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.27.1",
    "@chromatic-com/storybook": "^4.1.1",
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^18.1.0",
    "@figma/code-connect": "^1.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-links": "^9.1.7",
    "@storybook/addon-styling-webpack": "^2.0.0",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.1",
    "@storybook/react-webpack5": "^9.1.7",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^8.0.9",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^17.0.75",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.19.1",
    "babel-jest": "^29.7.0",
    "chromatic": "^11.29.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-storybook": "^9.1.7",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "semantic-release": "^22.0.5",
    "storybook": "^9.1.7",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      [
        "@semantic-release/exec",
        {
          "analyzeCommitsCmd": "echo patch"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/changelog",
      "@semantic-release/git"
    ]
  },
  "bugs": {
    "url": "https://github.com/encodium/rp-ui/issues"
  },
  "homepage": "https://github.com/encodium/rp-ui#readme",
  "exports": {
    "./rp-ui.css": "./src/styles/rp-ui.css",
    ".": "./src/index.js"
  }
}
